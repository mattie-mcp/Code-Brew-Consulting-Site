# Résumé-request form — frontend config.
# Both have safe defaults baked into the code, so a normal production build needs
# NEITHER of these. Copy to `.env` (or `.env.production`) only to override.

# Feature flag. Set to "false" to turn the form OFF site-wide: CTAs fall back to a
# plain mailto and the form is hidden. Anything else (or unset) = ON.
# Must match the backend flag (cdk -c formEnabled=false / Lambda FEATURE_ENABLED).
VITE_RESUME_FORM_ENABLED=true

# Origin of the form API. Defaults to https://api.codebrewconsulting.com.
VITE_API_BASE=https://api.codebrewconsulting.com
