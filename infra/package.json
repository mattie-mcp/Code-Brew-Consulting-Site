{
  "name": "code-brew-site-infra",
  "version": "1.0.0",
  "private": true,
  "description": "AWS CDK app for static hosting of codebrewconsulting.com (S3 + CloudFront + ACM + Route 53).",
  "bin": {
    "code-brew-site": "bin/code-brew-site.ts"
  },
  "scripts": {
    "build": "tsc",
    "synth": "cdk synth",
    "synth:staging": "cdk synth -c env=staging",
    "synth:prod": "cdk synth -c env=production",
    "diff": "cdk diff",
    "diff:staging": "cdk diff -c env=staging",
    "diff:prod": "cdk diff -c env=production",
    "deploy": "cdk deploy",
    "deploy:staging": "cdk deploy -c env=staging",
    "deploy:prod": "cdk deploy -c env=production",
    "destroy:staging": "cdk destroy -c env=staging"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "aws-cdk": "^2.160.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0"
  }
}
